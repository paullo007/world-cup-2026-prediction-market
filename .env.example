# PostgreSQL connection (Supabase: use the pooled connection string)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/worldcup"
# Supabase: direct (non-pooled) connection, used by prisma db push / migrations
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/worldcup"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-generate-with-openssl-rand-base64-32"

# Seed script: credentials of the admin account it creates
ADMIN_EMAIL="admin@worldcup.market"
ADMIN_PASSWORD="change-me-before-seeding"
