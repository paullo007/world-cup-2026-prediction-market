generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ADMIN
}

enum MarketStatus {
  OPEN
  CLOSED
  RESOLVED
}

enum Outcome {
  YES
  NO
}

enum TradeAction {
  BUY
  SELL
}

// Knockout bracket slot -> team, filled in by an admin as results come in.
// `slot` is the bracket position key (e.g. "74a", "89b", "104a").
model BracketAssignment {
  slot      String   @id
  team      String
  updatedAt DateTime @updatedAt
}

// Single-row ("singleton") app-wide state. `resultsFetchedAt` is the ONE global
// timestamp behind the results-refresh cooldown: both the daily cron and the
// public "Update Latest Results" button stamp it, and the button refuses to
// re-fetch the external sources unless it's older than the 60-minute cooldown.
// A single shared row (not per-user/per-IP) is all the throttle needs.
model SystemState {
  id               String    @id @default("singleton")
  resultsFetchedAt DateTime?
}

// One snapshot per day of the performance-adjusted (dynamic) AI champion, so the
// AI Knockouts page can flag a day-over-day change. date = "YYYY-MM-DD" (UTC).
model DailyChampion {
  date      String   @id
  champion  String
  pct       Float
  updatedAt DateTime @updatedAt
}

model User {
  id               String     @id @default(cuid())
  // Nickname auth (new users): public display name + case-insensitive unique key.
  nickname         String?
  nicknameLower    String?    @unique
  recoveryCodeHash String?
  // Legacy email/password auth (the original users + admin) — kept working.
  email            String?    @unique
  passwordHash     String?
  name             String
  role             Role       @default(USER)
  balance          Float      @default(1000)
  createdAt        DateTime   @default(now())
  positions        Position[]
  trades           Trade[]
}

model Market {
  id              String       @id @default(cuid())
  slug            String       @unique
  question        String
  description     String       @default("")
  category        String
  imageUrl        String?
  status          MarketStatus @default(OPEN)

  // Three-way group-stage matches: each fixture is 3 grouped binary markets
  // (Home win / Draw / Away win). matchKey ("Home vs Away") links the trio;
  // outcomeType says which outcome this market represents. Null for non-match
  // (binary) markets like tournament-winner or knockouts.
  matchKey    String? // e.g. "Brazil vs Morocco"
  outcomeType String? // "HOME" | "DRAW" | "AWAY"
  resolvedOutcome Outcome?
  closesAt        DateTime
  resolvedAt      DateTime?
  createdAt       DateTime     @default(now())

  // (C1) Auto-detected result from a sports API, awaiting admin approval before
  // payout. The cron sets these; an admin approves to trigger resolveMarket().
  pendingOutcome Outcome?
  resultSource   String? // e.g. "football-data.org"
  resultDetail   String? // human-readable, e.g. "Mexico 2–1 South Africa"
  fetchedAt      DateTime?

  // Structured score + goalscorers. The cron writes the pending* fields; an
  // admin approval copies them to the final fields. Standings / Scores / Goals
  // read only the final (approved) fields. scorers = [{ name, team, minute?, penalty? }].
  pendingHomeGoals Int?
  pendingAwayGoals Int?
  pendingScorers   Json?
  homeGoals        Int?
  awayGoals        Int?
  scorers          Json?

  // LMSR automated market maker state
  liquidity Float @default(1000) // LMSR "b" parameter
  qYes      Float @default(0) // outstanding YES shares
  qNo       Float @default(0) // outstanding NO shares

  positions Position[]
  trades    Trade[]

  @@index([status, closesAt])
}

model Position {
  id        String @id @default(cuid())
  userId    String
  marketId  String
  yesShares Float  @default(0)
  noShares  Float  @default(0)
  // total coins spent acquiring the current holding, for P&L display
  costBasis Float  @default(0)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  market Market @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@unique([userId, marketId])
}

model Trade {
  id         String      @id @default(cuid())
  userId     String
  marketId   String
  outcome    Outcome
  action     TradeAction
  shares     Float
  // coins paid (BUY) or received (SELL)
  amount     Float
  // YES probability after this trade, 0..1, for the price chart
  priceAfter Float
  createdAt  DateTime    @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  market Market @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@index([marketId, createdAt])
}
